<?xml version="1.0" encoding="UTF-8" ?>
<InputActions>
    <!-- Déplacements -->
    <Action label="Move" type="Vector2D">
        <!-- ZQSD -->
        <binding>
            <up bind="Z"/>
            <down bind="S"/>
            <left bind="Q"/>
            <right bind="D"/>
        </binding>
        <!-- fleches directionnelles -->
        <binding>
            <up bind="Up"/>
            <down bind="Down"/>
            <left bind="Left"/>
            <right bind="Right"/>
        </binding>
    </Action>
    <!-- coup d'épée -->
    <Action label="Slash" type="Button">
        <binding bind="O"/>
    </Action>
    <!-- coup de baguette -->
    <Action label="Wand" type="Button">
        <binding bind="P"/>
    </Action>
    <!-- Arc -->
    <Action label="Bow" type="Button">
        <binding bind="U"/>
    </Action>
</InputActions>