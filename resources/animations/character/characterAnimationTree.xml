<?xml version="1.0" encoding="UTF-8" ?>
<AnimationTree label="CharacterAnimator">
    <Parameters>
        <Parameter label="moving" default="false" type="Bool"/>
        <Parameter label="forwardWalk" default="0" type="Float"/>
        <Parameter label="sideWalk" default="0" type="Float"/>
        <Parameter label="slash" default="false" type="Trigger"/>
        <Parameter label="bow" default="false" type="Trigger"/>
        <Parameter label="wand" default="false" type="Trigger"/>
        <Parameter label="hit" default="false" type="Trigger"/>
    </Parameters>

    <EntryState label="Idle"/>
    <Tree>
        <Animation label="Idle" startx="0" starty="-1" length="2" frameDuration="300" loop="true" breakable="true">
            <Transition to="Move">
                <Condition parameter="moving" value="true"/>
            </Transition>
            <Transition to="Slash">
                <Condition parameter="slash" value="true"/>
            </Transition>
            <Transition to="Wand">
                <Condition parameter="wand" value="true"/>
            </Transition>
            <Transition to="Bow">
                <Condition parameter="bow" value="true"/>
            </Transition>
            <Transition to="Hit">
                <Condition parameter="hit" value="true"/>
            </Transition>
        </Animation>

        <BlendTree label="Move" src="resources/animations/character/moveBlendTree.xml">
            <Transition to="Idle">
                <Condition parameter="moving" value="false"/>
            </Transition>
            <Transition to="Slash">
                <Condition parameter="slash" value="true"/>
            </Transition>
            <Transition to="Wand">
                <Condition parameter="wand" value="true"/>
            </Transition>
            <Transition to="Bow">
                <Condition parameter="bow" value="true"/>
            </Transition>
            <Transition to="Hit">
                <Condition parameter="hit" value="true"/>
            </Transition>
        </BlendTree>

        <Animation label="Slash" startx="5" starty="-1" length="4" frameDuration="80" loop="false" breakable="false">
            <Transition to="Idle">
                <Condition parameter="moving" value="false"/>
            </Transition>
            <Transition to="Move">
                <Condition parameter="moving" value="true"/>
            </Transition>
        </Animation>

        <Animation label="Bow" startx="9" starty="-1" length="4" frameDuration="120" loop="false" breakable="false">
            <Transition to="Idle">
                <Condition parameter="moving" value="false"/>
            </Transition>
            <Transition to="Move">
                <Condition parameter="moving" value="true"/>
            </Transition>
        </Animation>

        <Animation label="Wand" startx="13" starty="-1" length="3" frameDuration="80" loop="false" breakable="false">
            <Transition to="Idle">
                <Condition parameter="moving" value="false"/>
            </Transition>
            <Transition to="Move">
                <Condition parameter="moving" value="true"/>
            </Transition>
        </Animation>

        <Animation label="Hit" startx="16" starty="-1" length="4" frameDuration="120" loop="false" breakable="false">
            <Transition to="Idle">
                <Condition parameter="moving" value="false"/>
            </Transition>
            <Transition to="Move">
                <Condition parameter="moving" value="true"/>
            </Transition>
        </Animation>

    </Tree>
</AnimationTree>
