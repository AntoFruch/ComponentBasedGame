<?xml version="1.0" encoding="UTF-8" ?>
<AnimationTree label="SlimeAnimator">
    <Parameters>
        <Parameter label="moving" default="false" type="Bool"/>
        <Parameter label="takeDamage" default="false" type="Trigger"/>
        <Parameter label="die" default="false" type="Trigger"/>
    </Parameters>

    <EntryState label="Idle"/>
    <Tree>
        <Animation label="Idle" startx="0" starty="-1" length="2" frameDuration="300" loop="true" breakable="true">
            <Transition to="Move">
                <Condition parameter="moving" value="true"/>
            </Transition>
            <Transition to="TakeDamage">
                <Condition parameter="takeDamage" value="true"/>
            </Transition>
            <Transition to="Die">
                <Condition parameter="die" value="true"/>
            </Transition>
        </Animation>

        <Animation label="Move" startx="2" starty="0" length="4" frameDuration="200" loop="true" breakable="true">
            <Transition to="Idle">
                <Condition parameter="moving" value="false"/>
            </Transition>
            <Transition to="TakeDamage">
                <Condition parameter="takeDamage" value="true"/>
            </Transition>
            <Transition to="Die">
                <Condition parameter="die" value="true"/>
            </Transition>
        </Animation>

        <Animation label="TakeDamage" startx="6" starty="-1" length="3" frameDuration="300" loop="false" breakable="false">
            <Transition to="Idle">
                <Condition parameter="moving" value="false"/>
            </Transition>
            <Transition to="Move">
                <Condition parameter="moving" value="true"/>
            </Transition>
        </Animation>
        <Animation label="Die" startx="6" starty="-1" length="3" frameDuration="300" loop="true" breakable="true">
        </Animation>


    </Tree>
</AnimationTree>
